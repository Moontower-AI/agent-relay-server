# HTTP
PORT=3000
TRUST_PROXY=0

# MongoDB
MONGO_URI=mongodb://localhost:27017/agent-relay

# Admin bootstrap token — long random string, e.g. `openssl rand -hex 32`
ADMIN_TOKEN=replace-me-with-a-long-random-string

# AES-256-GCM key for encrypting webhook secrets at rest.
# Must be exactly 32 bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace-me-with-32-random-bytes-base64

# Logging
LOG_LEVEL=info
